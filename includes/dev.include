DEV_MOUNT=""

add_dev_if_exists () {
	if [ -e "$1" ]
	then
		DEV_MOUNT="$DEV_MOUNT -v '$1':'$1'"
	fi
}

for hidraw in /dev/hidraw*
do
	add_dev_if_exists "$hidraw"
done

add_dev_if_exists /dev/input
add_dev_if_exists /dev/dri
add_dev_if_exists /dev/ntsync
add_dev_if_exists /dev/uinput
add_dev_if_exists /dev/kvm

# gamescope mode, requires seatd running and the socket accessible for your current user
# steam has to be initialized already as well, otherwise it'll get stuck for not being able to communicate with NetworkManager
add_dev_if_exists /run/seatd.sock
add_dev_if_exists /run/udev
