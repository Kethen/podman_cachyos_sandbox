add_mount () {
	if ! [ -e "$1" ]
	then
		mkdir -p "$1"
	fi
	MOUNT="$MOUNT -v '$1':'$2'"
	if [ -n "$3" ]
	then
		MOUNT="$MOUNT:$3"
	fi
}


MOUNT=""
add_mount "./home_dir" "/home_dir"
add_mount "./ro_mnt" "/ro mnt" ro

MOUNT="$MOUNT -w /home_dir"
MOUNT="$MOUNT --env HOME=/home_dir"

unset -f add_mount
